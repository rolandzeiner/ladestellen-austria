# IMPORTANT: review before committing. Order = most likely to leak first.

# ---------------------------------------------------------------------------
# Rule #0 — API-key & credential leak vectors
# ---------------------------------------------------------------------------
secrets.json
secrets.yaml
.secrets
.env
.env.*
!.env.example
*.secret
credentials.json
token.json
auth.json
*.pem
*.key
*.p12
*.pfx
local_*.py
private_*.py
tests/fixtures/secrets/

# Swagger spec + any local scratch lives here, never committed.
dev/

# ---------------------------------------------------------------------------
# Claude / AI tooling — caches ignored, project-level skills tracked
# ---------------------------------------------------------------------------
.claude/*
!.claude/skills/
.claude-cache/
.claude-*
CLAUDE.local.md
*.local.md
.aider*
.cursor/
.cursorrules.local
.continue/
.windsurf/

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
.python-version

# ---------------------------------------------------------------------------
